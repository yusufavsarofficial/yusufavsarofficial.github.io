{
  "name": "yusuf-portfolio",
  "version": "1.0.0",
  "description": "Yusuf Avşar'ın güvenlik odaklı geliştirme portfolyosu",
  "main": "index.html",
  "scripts": {
    "minify-js": "terser app.js admin-auth.js main.js -o dist/app.min.js --compress --mangle",
