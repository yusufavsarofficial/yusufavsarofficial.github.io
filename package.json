    "build": "npm run minify-js && npm run minify-css",
    "start": "python -m http.server 8000"
  },
  "keywords": [
    "portfolio",
    "security",
    "development",
    "golang",
    "python",
    "devsecops"
  ],
  "author": "Yusuf Avşar",
  "license": "ISC",
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "terser": "^5.31.0"
  }
}
